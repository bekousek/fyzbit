{
  "name": "fyzbit",
  "version": "0.1.0",
  "description": "FyzBit — webový datalogger pro micro:bit s fyzikálními senzory (ZŠ/SŠ)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,css,json,html}\" \"tests/**/*.ts\" \"*.{json,html,md,ts}\""
  },
  "keywords": [
    "microbit",
    "physics",
    "datalogger",
    "education",
    "fyzika"
  ],
  "author": "Ondřej Bek",
  "license": "MIT",
  "homepage": "https://bekousek.github.io/fyzbit",
  "repository": {
    "type": "git",
    "url": "https://github.com/bekousek/fyzbit.git"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "idb-keyval": "^6.2.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
